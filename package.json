{
  "name": "secteur-v-client",
  "version": "1.1.0",
  "description": "Secteur V Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.secteurv.client",
    "productName": "Secteur V",
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "cscLink": "build/secteur-v.pfx",
      "verifyUpdateCodeSignature": false
    },
    "publish": [{
      "provider": "github",
      "owner": "killian1307",
      "repo": "secteur-v-client" 
    }]
  },
  "keywords": ["secteur-v", "tournament", "inazuma-eleven", "matchmaking", "desktop-client"],
  "author": "LetterK <secteur-v@letterk.me>",
  "license": "UNLICENSED",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3"
  }
}
